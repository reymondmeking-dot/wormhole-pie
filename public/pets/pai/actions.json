      "cooldownMs": 1000,
      "markers": { "showError": 4 },
      "needEffect": { "mood": -4 }
    },
    "permission_wait": {
      "group": "agent_extended",
      "priority": 95,
      "mode": "hold_last_ping_pong",
      "sequence": [2, 3, 4, 3],
