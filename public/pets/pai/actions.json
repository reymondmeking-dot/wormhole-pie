      "markers": { "showResult": 4 }
    },
    "trash_fail_cough": {
      "group": "file_extended",
      "priority": 90,
      "mode": "once",
      "fps": 13,
      "interrupt": "loop_boundary",
      "cooldownMs": 500,
      "markers": { "showError": 4 }
    }
  },
  "proceduralLayers": {
    "eye_track_cursor": {
      "priority": 58,
      "updateHz": 30,
      "maxOffsetPercent": 5,
      "disabledDuring": ["sleep", "drag", "file_eat", "run", "emotion_sad"]
    },
    "head_track_cursor": {
      "priority": 52,
      "updateHz": 20,
      "maxRotateDeg": 7,
      "maxTranslatePxAt256": 4,
      "disabledDuring": ["sleep", "drag", "file_eat", "run"]
    },
    "secondary_motion": {
      "updateHz": 60,
      "targets": ["ears", "tail", "charm"],
      "spring": 0.18,
      "damping": 0.72
    },
    "blink_overlay": {
      "randomIntervalMs": [4000, 12000],
      "durationMs": 140,
      "fallbackAction": "blink"
    },
    "shadow_layer": {
      "separate": true,
      "hideDuring": ["hop", "release_bounce", "drag", "hide_peek"]
    }
  }
}
