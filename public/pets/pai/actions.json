    "dance": {
      "group": "daily",
      "priority": 30,
      "mode": "ping_pong",
      "sequence": [2, 3, 4, 3],
      "fps": 14,
      "interrupt": "loop_boundary",
      "randomCooldownMs": [1800000, 5400000],
