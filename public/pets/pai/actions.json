      "autonomous": true,
      "weight": 22
    },
    "yawn": {
      "group": "micro_life",
      "priority": 30,
      "mode": "once",
      "fps": 9,
      "interrupt": "loop_boundary",
      "randomCooldownMs": [300000, 900000],
      "autonomous": true,
      "weight": 8,
      "needBias": { "sleepiness": 0.8, "energy": -0.5 }
