{
  "version": 2,
  "framePattern": "../frames/{size}/{pet}/{action}/{frame}.png",
  "defaults": {
    "frames": 4,
    "anchor": "feet_center",
    "lockFrame1": true,
    "blendInMs": 80,
    "blendOutMs": 120,
    "sequence": [1, 2, 3, 4]
  },
  "actions": {
    "idle_breathe": {
      "group": "life",
      "priority": 10,
      "mode": "loop",
      "sequence": [1, 2, 3, 4, 3, 2],
      "fps": 6,
      "interrupt": "immediate",
      "cooldownMs": 0,
      "autonomous": true,
      "weight": 100
    },
    "walk": {
      "group": "life",
      "priority": 62,
      "mode": "loop",
      "sequence": [2, 3, 4, 3],
      "entrySequence": [1, 2],
      "fps": 10,
      "interrupt": "immediate",
      "directional": true,
      "mirrorSafe": false
    },
    "sleep": {
      "group": "life",
      "priority": 35,
      "mode": "hold_last_ping_pong",
      "sequence": [1, 2, 3, 4, 3, 2],
      "fps": 5,
      "interrupt": "loop_boundary",
      "holdLastMs": 1800
    },
    "click_feedback": {
      "group": "life",
      "priority": 88,
      "mode": "once",
      "fps": 14,
      "interrupt": "loop_boundary",
      "cooldownMs": 220
    },
    "listen": {
      "group": "agent",
      "priority": 87,
      "mode": "ping_pong",
      "sequence": [1, 2, 3, 4, 3, 2],
      "fps": 9,
      "interrupt": "immediate",
      "markers": { "vadReady": 2 }
    },
    "think": {
      "group": "agent",
      "priority": 84,
      "mode": "ping_pong",
      "sequence": [1, 2, 3, 4, 3, 2],
      "fps": 7,
      "interrupt": "immediate",
      "longWaitFallback": "permission_wait"
    },
    "task_success": {
      "group": "agent",
      "priority": 88,
      "mode": "once",
      "fps": 12,
      "interrupt": "loop_boundary",
      "markers": { "sfx": 2, "showResult": 4 }
    },
    "file_eat": {
      "group": "agent",
      "priority": 100,
      "mode": "once",
      "fps": 12,
      "interrupt": "key_marker",
      "markers": { "bite": 2, "commitToRecycleBin": 3, "finish": 4 },
      "requiresConfirmation": true
    },
    "drag": {
      "group": "social",
      "priority": 95,
      "mode": "velocity_driven",
      "sequence": [2, 3, 4, 3],
      "fps": 12,
      "interrupt": "immediate",
      "markers": { "held": 2, "sway": 3, "release": 4 }
    },
    "rest_reminder": {
      "group": "social",
      "priority": 58,
      "mode": "hold_last",
      "fps": 8,
      "interrupt": "loop_boundary",
      "cooldownMs": 1200000
    },
    "affection": {
      "group": "social",
      "priority": 75,
      "mode": "once",
      "fps": 10,
      "interrupt": "loop_boundary",
      "cooldownMs": 600
    },
    "hide_peek": {
      "group": "social",
      "priority": 68,
      "mode": "ping_pong",
      "sequence": [1, 2, 3, 4, 3, 2],
      "fps": 7,
      "interrupt": "immediate"
    },

    "blink": {
      "group": "micro_life",
      "priority": 15,
      "mode": "once",
      "fps": 16,
      "interrupt": "immediate",
      "randomCooldownMs": [15000, 45000],
      "autonomous": true,
      "weight": 42
    },
    "ear_twitch": {
      "group": "micro_life",
      "priority": 15,
      "mode": "once",
      "fps": 12,
      "interrupt": "immediate",
      "randomCooldownMs": [30000, 90000],
      "autonomous": true,
      "weight": 24
    },
    "tail_flick": {
      "group": "micro_life",
      "priority": 15,
      "mode": "once",
      "fps": 10,
      "interrupt": "immediate",
